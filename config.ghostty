# === Appearance ===
background-opacity = 0.95
background-blur = true
background-blur-radius = 16
theme = Catppuccin Mocha

# === Font ===
font-family = JetBrainsMono Nerd Font
font-size = 14
font-thicken = true
adjust-cell-height = 2

# === Window ===
window-width = 130
window-height = 36
window-padding-x = 12
window-padding-y = 12

# === Behavior ===
link-url = true